  - name: airport_B
    type: generic
    title: 机场B
    icon: antenna.radiowaves.left.and.right
    script: https://raw.githubusercontent.com/IBL3ND/module/refs/heads/main/subscription-userinfo.js

  - name: airport_C
    type: generic
    title: 机场C
